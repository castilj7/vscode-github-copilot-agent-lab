<div class="fixed inset-0 retro-modal-backdrop flex items-center justify-center p-4 z-50">
    <div class="retro-modal p-6 max-w-xs w-full text-center">
        <div class="text-5xl mb-4">🎉</div>
        <h2 class="retro-modal-title mb-2">BINGO!</h2>
        <p class="retro-copy mb-6">You completed a line!</p>

        <button
            @onclick="OnDismiss"
            class="retro-btn w-full py-3 px-6">
            Keep Playing
        </button>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnDismiss { get; set; }
}
