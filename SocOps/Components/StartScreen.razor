<div class="retro-game-shell flex flex-col items-center justify-center min-h-full p-6">
    <div class="retro-window text-center p-6">
        <h1 class="retro-title mb-2">Soc Ops</h1>
        <p class="retro-subtitle mb-6">Social Bingo</p>

        <div class="retro-panel p-6 mb-6">
            <h2 class="retro-heading mb-3">How to play</h2>
            <ul class="retro-list text-left">
                <li>Find people who match the questions</li>
                <li>Tap a square when you find a match</li>
                <li>Get 5 in a row to win!</li>
            </ul>
        </div>

        <button
            @onclick="OnStart"
            class="retro-btn w-full py-4 px-8">
            Start Game
        </button>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnStart { get; set; }
}
