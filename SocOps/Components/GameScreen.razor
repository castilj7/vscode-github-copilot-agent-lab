@using SocOps.Models

<div class="retro-game-shell flex flex-col min-h-full">
    <!-- Header -->
    <header class="retro-header flex items-center justify-between p-3">
        <button
            @onclick="OnReset"
            class="retro-btn retro-btn-muted px-3 py-1.5">
            BACK
        </button>
        <h1 class="retro-header-title">Soc Ops</h1>
        <div class="w-16"></div>
    </header>

    <!-- Instructions -->
    <p class="retro-instruction-strip text-center py-2 px-4">
        Tap a square when you find someone who matches it.
    </p>

    <!-- Bingo indicator -->
    @if (HasBingo)
    {
        <div class="retro-bingo-banner text-center py-2">
            🎉 BINGO! You got a line!
        </div>
    }

    <!-- Board -->
    <div class="flex-1 flex items-center justify-center p-3">
        <BingoBoard
            Board="@Board"
            WinningSquareIds="@WinningSquareIds"
            OnSquareClick="@OnSquareClick" />
    </div>
</div>

@code {
    [Parameter]
    public List<BingoSquareData> Board { get; set; } = new();

    [Parameter]
    public HashSet<int> WinningSquareIds { get; set; } = new();

    [Parameter]
    public bool HasBingo { get; set; }

    [Parameter]
    public EventCallback<int> OnSquareClick { get; set; }

    [Parameter]
    public EventCallback OnReset { get; set; }
}
